@model BoardGameHub.Models.DbModels.Publisher

@{
    ViewData["Title"] = "Create";
}

<h1>Utwórz</h1>

<h4>Wydawca</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="BoardGames" class="control-label"></label>
                <input asp-for="BoardGames" class="form-control" />
                <span asp-validation-for="BoardGames" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mb-4 mt-2">
    <a asp-action="ViewAll" class="text-decoration-none text-muted-sm">
        &larr; Wróć do katalogu
    </a>
</div>
